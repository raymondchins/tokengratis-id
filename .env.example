# tokengratis.id — environment variables
#
# Copy to `.env` (gitignored) and set only what you need.
# Everything here is OPTIONAL: the site builds and runs with NONE of these set.
# (The data pipeline degrades gracefully; the dormant newsletter route returns 503.)

# ── Data pipeline LLM fallback (scripts/sync.mjs) ─────────────────────────────
# Re-parses unstructured sources (freellm HTML / cheahjs markdown) only when they
# drift below the regex sanity floor. Needs ONE of these; if neither is set the
# fallback is simply OFF and sync runs normally.
# ANTHROPIC_API_KEY=          # raw Anthropic API (billed per token)
# CLAUDE_CODE_OAUTH_TOKEN=    # headless Claude Code (subscription quota) — `claude setup-token`
# LLM_FALLBACK_BACKEND=       # optional: force "api" or "cli" (default: auto-detect)

# ── Open-source directory sync (scripts/sync-opensource.mjs) ──────────────────
# Avoids GitHub's 60 req/hr unauthenticated rate limit. In GitHub Actions,
# GITHUB_TOKEN is injected automatically; locally a personal token also works.
# GITHUB_TOKEN=
# GITHUB_PAT=

# ── Newsletter route (app/api/subscribe — dormant, not mounted in the UI) ─────
# Without these the route returns 503; the rest of the site is unaffected.
# RESEND_API_KEY=
# RESEND_AUDIENCE_ID=
