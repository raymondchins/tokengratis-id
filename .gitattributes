# Keep the repomap engine byte-identical across repos (md5 invariant) and shell
# hooks LF-executable on checkout, regardless of core.autocrlf on Windows.
scripts/repomap.mjs text eol=lf
*.sh text eol=lf

# normalize source text files to LF (added during Windows->Mac migration)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

* text=auto eol=lf
